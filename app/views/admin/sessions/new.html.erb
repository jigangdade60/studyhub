<div class="container py-4" style="max-width: 640px;">
  <div class="border rounded-4 bg-white">
    <div class="p-4">

      <!-- タイトル -->
      <div class="mb-4 text-center">
        <h5 class="fw-bold mb-1">管理者ログイン</h5>
        <p class="text-muted small mb-0">
          管理画面にログインします
        </p>
      </div>

      <!-- エラー -->
      <% if flash[:alert] %>
        <div class="alert alert-danger">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: admin_login_path, method: :post, local: true do |f| %>

        <!-- メール -->
        <div class="mb-3">
          <%= f.label :email_address, "メールアドレス",
                      class: "form-label fw-semibold small text-muted" %>
          <%= f.email_field :email_address,
                            class: "form-control rounded-pill border-0 bg-light py-3 px-4",
                            placeholder: "メールアドレスを入力",
                            required: true %>
        </div>

        <!-- パスワード -->
        <div class="mb-4">
          <%= f.label :password, "パスワード",
                      class: "form-label fw-semibold small text-muted" %>
          <%= f.password_field :password,
                               class: "form-control rounded-pill border-0 bg-light py-3 px-4",
                               placeholder: "パスワードを入力",
                               required: true %>
        </div>

        <!-- ボタン -->
        <div class="d-grid">
          <%= f.submit "ログイン",
                       class: "btn rounded-pill py-3 fw-bold text-white",
                       style: "background-color: #111;" %>
        </div>

      <% end %>

    </div>
  </div>
</div>
