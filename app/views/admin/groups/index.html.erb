<div class="container py-4" style="max-width: 1100px;">
  <div class="mb-4">
    <h2 class="fw-bold mb-1">もくもく会管理</h2>
    <p class="text-muted mb-0">全てのもくもく会を確認し、必要に応じて削除できます。</p>
  </div>

  <% if @groups.empty? %>
    <div class="alert alert-secondary">
      もくもく会はまだ作成されていません。
    </div>
  <% else %>
    <div class="card shadow-sm border-0">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>ID</th>
                <th>もくもく会名</th>
                <th>テーマ</th>
                <th>作成者</th>
                <th>参加人数</th>
                <th>作成日</th>
                <th class="text-center">操作</th>
              </tr>
            </thead>
            <tbody>
              <% @groups.each do |group| %>
                <tr>
                  <td><%= group.id %></td>
                  <td class="fw-semibold"><%= group.name %></td>
                  <td><%= group.study_theme %></td>
                  <td><%= group.owner.name %></td>
                  <td><%= group.members.count %> / <%= group.max_members %></td>
                  <td><%= l group.created_at, format: :short %></td>
                  <td class="text-center">
                    <%= button_to "削除",
                                  admin_group_path(group),
                                  method: :delete,
                                  data: { turbo_confirm: "このもくもく会を削除しますか？" },
                                  class: "btn btn-sm btn-outline-danger" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>
</div>