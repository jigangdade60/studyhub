<div class="container py-3" style="max-width: 700px;">

  <!-- タイトル -->
  <div class="mb-3">
    <h5 class="fw-bold mb-0">もくもく会管理</h5>
    <p class="text-muted small mb-0">全てのもくもく会を確認し、必要に応じて削除できます。</p>
  </div>

  <!-- 一覧 -->
  <% if @groups.empty? %>
    <div class="bg-white border rounded-4 p-4 text-muted text-center">
      もくもく会はまだ作成されていません。
    </div>
  <% else %>

    <% @groups.each do |group| %>
      <div class="bg-white border rounded-4 mb-3 x-hover">

        <div class="p-3">
          <div class="d-flex gap-3">

            <!-- アイコン -->
            <div>
              <%= user_avatar(group.owner, size: 48) %>
            </div>

            <!-- コンテンツ -->
            <div class="flex-grow-1">

              <!-- 作成者名＋作成日時 -->
              <div class="mb-1 d-flex justify-content-between align-items-start flex-wrap gap-2">
                <div>
                  <span class="fw-bold text-dark"><%= group.owner.name %></span>
                  <span class="text-muted small ms-2">
                    <%= l group.created_at, format: :short %>
                  </span>
                </div>

                <span class="text-muted small">ID: <%= group.id %></span>
              </div>

              <!-- タイトル -->
              <div class="fw-bold text-dark mb-2">
                <%= group.name %>
              </div>

              <!-- 説明 -->
              <% if group.description.present? %>
                <div class="text-dark mb-2">
                  <%= truncate(group.description, length: 100) %>
                </div>
              <% end %>

              <!-- テーマ・参加人数 -->
              <div class="mb-3 d-flex flex-wrap gap-2">
                <% if group.study_theme.present? %>
                  <span class="badge bg-light text-dark border rounded-pill px-3 py-2">
                    #<%= group.study_theme %>
                  </span>
                <% end %>

                <span class="badge bg-light text-dark border rounded-pill px-3 py-2">
                  <i class="fa-solid fa-user-group me-1"></i>
                  <%= group.members.count %>/<%= group.max_members %>人
                </span>
              </div>

              <!-- 下部 -->
              <div class="d-flex justify-content-between align-items-center text-muted small pt-2 border-top flex-wrap gap-3">
                <div class="d-flex align-items-center gap-4 flex-wrap">
                  <div class="d-flex align-items-center gap-1">
                    <i class="fa-solid fa-user-group"></i>
                    <span><%= group.members.count %>人参加中</span>
                  </div>

                  <div class="d-flex align-items-center gap-1">
                    <% if group.full? %>
                      <i class="fa-solid fa-circle-exclamation text-danger"></i>
                      <span class="text-danger">満員</span>
                    <% else %>
                      <i class="fa-regular fa-circle-check text-success"></i>
                      <span class="text-success">募集中</span>
                    <% end %>
                  </div>
                </div>

                <div>
                  <%= button_to "削除",
                        admin_group_path(group),
                        method: :delete,
                        data: { turbo_confirm: "このもくもく会を削除しますか？" },
                        class: "btn btn-sm btn-outline-danger rounded-pill px-3" %>
                </div>
              </div>

            </div>
          </div>
        </div>

      </div>
    <% end %>

  <% end %>
</div>

<div class="mt-0 mb-5 d-flex justify-content-center">
  <%= paginate @groups %>
</div>