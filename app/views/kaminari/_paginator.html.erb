<%= paginator.render do -%>
  <nav class="studyhub-pagination-wrap" aria-label="Pagination">
    <ul class="studyhub-pagination">
      <%= prev_page_tag unless current_page.first? %>

      <% each_page do |page| -%>
        <% if page.display_tag? -%>
          <%= page_tag page %>
        <% elsif !page.was_truncated? -%>
          <%= gap_tag %>
        <% end -%>
      <% end -%>

      <%= next_page_tag unless current_page.last? %>
    </ul>
  </nav>
<% end -%>