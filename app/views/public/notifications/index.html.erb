<div class="container py-4" style="max-width: 800px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-1">通知一覧</h2>
      <p class="text-muted mb-0">最新の通知を確認できます。</p>
    </div>
  </div>

  <% if @notifications.empty? %>
    <div class="alert alert-secondary rounded-4">
      通知はまだありません。
    </div>
  <% else %>
    <div class="d-flex flex-column gap-3">
      <% @notifications.each do |notification| %>
        <div class="card shadow-sm border-0 rounded-4 <%= 'border-start border-4 border-primary' unless notification.read? %>">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start gap-3">
              <div>
                <p class="mb-1 fw-semibold"><%= notification.message %></p>
                <small class="text-muted">
                  <%= l notification.created_at, format: :short %>
                </small>
              </div>

              <div>
                <%= link_to "開く",
                            read_notification_path(notification),
                            data: { turbo_method: :patch },
                            class: "btn btn-outline-primary btn-sm rounded-pill" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>