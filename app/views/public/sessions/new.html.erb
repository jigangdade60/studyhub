<div class="container mt-5" style="max-width: 500px;">
  <h2 class="mb-4 text-center">ログイン</h2>

  <%= form_with url: session_path, local: true do |f| %>
    <div class="mb-3">
      <%= f.label :email_address, "メールアドレス", class: "form-label" %>
      <%= f.email_field :email_address, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :password, "パスワード", class: "form-label" %>
      <%= f.password_field :password, class: "form-control" %>
    </div>

    <div class="d-grid">
      <%= f.submit "ログイン", class: "btn btn-primary" %>
    </div>
  <% end %>

  <div class="mt-3 text-center">
    <%= link_to "新規登録はこちら", new_user_path %>
  </div>
</div>