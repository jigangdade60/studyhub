<div class="container py-4" style="max-width: 900px;">
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body">

      <!-- ユーザー名 + フォローボタン -->
      <div class="d-flex justify-content-between align-items-center mb-2">
        <div>
          <h2 class="fw-bold mb-1"><%= @user.name %></h2>

          <% if @user.is_public? %>
            <span class="badge bg-success">公開中</span>
          <% else %>
            <span class="badge bg-secondary">非公開</span>
          <% end %>
        </div>

        <% if authenticated? && Current.user != @user %>
          <div class="d-flex flex-column align-items-end gap-2">
            <%= render "public/relationships/btn", user: @user %>

            <% if Current.user.mutual_follow_with?(@user) %>
              <%= button_to "DMする",
                            dm_rooms_path(user_id: @user.id),
                            method: :post,
                            class: "btn btn-outline-primary btn-sm rounded-pill px-4" %>
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- フォロー数 -->
      <p class="mb-2">
        <%= link_to "フォロー中 #{@user.following.count}人",
                    following_user_path(@user),
                    class: "text-decoration-none me-3" %>

        <%= link_to "フォロワー #{@user.followers.count}人",
                    followers_user_path(@user),
                    class: "text-decoration-none" %>
      </p>

      <p class="text-muted mb-0">投稿一覧を表示しています。</p>
    </div>
  </div>

  <% if @posts.any? %>
    <div class="d-flex flex-column gap-3">
      <% @posts.each do |post| %>
        <div class="card shadow-sm border-0">
          <div class="card-body">
            <h5 class="fw-bold mb-2"><%= post.title %></h5>
            <p class="text-muted mb-2">
              <%= post.created_at.strftime("%Y/%m/%d") %>
              ・コメント <%= post.comments.count %>件
            </p>
            <p class="mb-0"><%= truncate(post.body, length: 100) %></p>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-secondary">
      まだ投稿がありません。
    </div>
  <% end %>
</div>