<div class="container py-3" style="max-width: 700px;">

  <!-- タイトル -->
  <div class="mb-3">
    <h5 class="fw-bold mb-0">ユーザー検索</h5>
    <p class="text-muted small mb-0">ユーザー名で検索できます。</p>
  </div>

  <!-- 検索 -->
  <div class="mb-3">
    <%= form_with url: users_path, method: :get, local: true do |f| %>
      <%= f.text_field :keyword,
                       value: @keyword,
                       class: "form-control rounded-pill",
                       placeholder: "ユーザー名を入力" %>
    <% end %>
  </div>

  <!-- 一覧 -->
  <% if @users.any? %>
    <% @users.each do |user| %>
      <div class="bg-white border rounded-4 mb-3 x-hover x-user-card"
           style="cursor: pointer;"
           onclick="window.location='<%= user_path(user) %>'">

        <div class="p-3 w-100">
          <div class="d-flex gap-3 align-items-center">

            <!-- アイコン -->
            <div onclick="event.stopPropagation();">
              <%= link_to user_path(user) do %>
                <%= user_avatar(user, size: 48) %>
              <% end %>
            </div>

            <!-- コンテンツ -->
            <div class="flex-grow-1">

              <!-- 名前 -->
              <div class="mb-2 d-flex align-items-center gap-2 flex-wrap">
                <span onclick="event.stopPropagation();">
                  <%= link_to user.name,
                              user_path(user),
                              class: "fw-bold text-dark text-decoration-none" %>
                </span>

                <% if authenticated? && Current.user == user %>
                  <% if user.is_public? %>
                    <span class="badge bg-success rounded-pill">公開中</span>
                  <% else %>
                    <span class="badge bg-secondary rounded-pill">非公開</span>
                  <% end %>
                <% end %>
              </div>

              <!-- 下部 -->
              <div class="d-flex justify-content-between align-items-center text-muted small flex-wrap gap-2">

                <!-- 左 -->
                <div class="d-flex align-items-center gap-4">

                  <div class="d-flex align-items-center gap-1"
                       onclick="event.stopPropagation();">
                    <i class="fa-solid fa-user-plus"></i>
                    <%= link_to following_user_path(user),
                                class: "text-decoration-none text-muted" do %>
                      <span><%= user.following.count %> フォロー中</span>
                    <% end %>
                  </div>

                  <div class="d-flex align-items-center gap-1"
                       onclick="event.stopPropagation();">
                    <i class="fa-solid fa-users"></i>
                    <%= link_to followers_user_path(user),
                                class: "text-decoration-none text-muted" do %>
                      <span><%= user.followers.count %> フォロワー</span>
                    <% end %>
                  </div>

                </div>

                <!-- 右 -->
                <div class="x-user-action" onclick="event.stopPropagation();">
                  <% if authenticated? && Current.user != user %>
                    <%= render "public/relationships/btn", user: user %>
                  <% end %>
                </div>

              </div>

            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="bg-white border rounded-4 p-4 text-muted text-center">
      該当するユーザーがいません。
    </div>
  <% end %>
</div>
<div class="mt-0 mb-5 d-flex justify-content-center">
  <%= paginate @users %>
</div>