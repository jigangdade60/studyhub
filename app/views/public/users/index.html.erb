<div class="container py-4" style="max-width: 900px;">
  <!-- ページタイトル -->
  <div class="mb-4">
    <h2 class="fw-bold mb-1">ユーザー検索</h2>
    <p class="text-muted mb-0">ユーザー名で検索できます。</p>
  </div>

  <!-- 検索フォーム -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
      <%= form_with url: users_path, method: :get, local: true do |f| %>
        <div class="row g-2">
          <div class="col-md-9">
            <%= f.text_field :keyword,
                             value: @keyword,
                             class: "form-control",
                             placeholder: "ユーザー名を入力" %>
          </div>
          <div class="col-md-3 d-grid">
            <%= f.submit "検索", class: "btn btn-primary" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 検索結果 -->
  <% if @users.any? %>
    <div class="d-flex flex-column gap-3">
      <% @users.each do |user| %>
        <div class="card shadow-sm border-0">
          <div class="card-body d-flex justify-content-between align-items-center">
            <div>
              <div class="d-flex align-items-center gap-2 mb-1">
                <h5 class="fw-bold mb-0"><%= user.name %></h5>

                <% if authenticated? && Current.user == user %>
                  <% if user.is_public? %>
                    <span class="badge bg-success">公開中</span>
                  <% else %>
                    <span class="badge bg-secondary">非公開</span>
                  <% end %>
                <% end %>
              </div>

              <p class="text-muted mb-1">
                投稿数：<%= user.posts.count %>件
              </p>

              <p class="mb-0 small">
                <%= link_to "フォロー中 #{user.following.count}人",
                            following_user_path(user),
                            class: "text-decoration-none me-3" %>
                <%= link_to "フォロワー #{user.followers.count}人",
                            followers_user_path(user),
                            class: "text-decoration-none" %>
              </p>
            </div>

            <div class="d-flex gap-2 align-items-center">
              <% if authenticated? && Current.user != user %>
                <%= render "public/relationships/btn", user: user %>
              <% end %>

              <%= link_to "詳細を見る", user_path(user), class: "btn btn-outline-primary" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-secondary">
      該当するユーザーがいません。
    </div>
  <% end %>
</div>