<div class="container py-4" style="max-width: 800px;">
  <h2 class="fw-bold mb-4"><%= @user.name %>さんのフォロー中一覧</h2>

  <% if @users.any? %>
    <% @users.each do |user| %>
      <div class="card shadow-sm mb-3">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <h5 class="mb-1">
              <%= link_to user.name, user_path(user), class: "text-decoration-none" %>
            </h5>
            <small class="text-muted">
              フォロー中 <%= user.following.count %> ・ フォロワー <%= user.followers.count %>
            </small>
          </div>

          <% if authenticated? %>
            <%= render "public/relationships/btn", user: user %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="alert alert-secondary">まだフォローしているユーザーはいません。</div>
  <% end %>
</div>