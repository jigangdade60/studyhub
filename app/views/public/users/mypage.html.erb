<div class="container py-4">
  <!-- ページタイトル -->
  <div class="mb-4">
    <h2 class="fw-bold text-primary">マイページ</h2>
    <p class="text-muted mb-0">ログイン中のユーザー情報と投稿一覧を確認できます。</p>
  </div>

  <!-- 学習サマリー -->
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <p class="text-muted mb-1">投稿数</p>
          <h4 class="fw-bold mb-0"><%= @posts_count %>件</h4>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <p class="text-muted mb-1">累計学習時間</p>
          <h4 class="fw-bold mb-0"><%= format_study_time(@total_study_time) %></h4>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <p class="text-muted mb-1">今週の学習時間</p>
          <h4 class="fw-bold mb-0"><%= format_study_time(@weekly_study_time) %></h4>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <p class="text-muted mb-1">連続学習日数</p>
          <h4 class="fw-bold mb-0"><%= @streak_days %>日</h4>
        </div>
      </div>
    </div>
  </div>

  <!-- 学習グラフ -->
  <div class="mb-4">
    <div class="card shadow-sm">
      <div class="card-header bg-light">
        直近7日間の学習時間
      </div>
      <div class="card-body">
        <canvas id="studyTimeChart"></canvas>
      </div>
    </div>
  </div>

  <div class="row">
    <!-- ユーザー情報 -->
    <div class="col-md-4 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
          ユーザー情報
        </div>
        <div class="card-body">
          <p>
            <strong>氏名：</strong>
            <%= @user.name %>
          </p>

          <p>
            <strong>メールアドレス：</strong>
            <%= @user.email_address %>
          </p>

          <div class="d-grid gap-2 mt-4">
            <%= link_to "編集する", edit_user_path(@user), class: "btn btn-outline-primary" %>

            <%= button_to "退会する",
                          user_path(@user),
                          method: :delete,
                          data: { turbo_confirm: "本当に退会しますか？この操作は取り消せません。" },
                          class: "btn btn-outline-danger" %>
          </div>
        </div>
      </div>
    </div>

    <!-- 自分の投稿一覧 -->
    <div class="col-md-8">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          自分の投稿一覧
        </div>
        <div class="card-body">
          <% if @posts.any? %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>投稿ID</th>
                    <th>学習時間</th>
                    <th>投稿日</th>
                    <th>詳細</th>
                  </tr>
                </thead>
                <tbody>
                  <% @posts.each do |post| %>
                    <tr>
                      <td><%= post.id %></td>
                      <td><%= format_study_time(post.study_time) %></td>
                      <td><%= post.created_at.strftime("%Y/%m/%d %H:%M") %></td>
                      <td>
                        <%= link_to "見る", post_path(post), class: "btn btn-sm btn-outline-secondary" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-muted mb-0">まだ投稿がありません。</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- もくもく会セクション -->
  <div class="mt-5">
    <div class="mb-4">
      <h3 class="fw-bold text-primary">もくもく会情報</h3>
      <p class="text-muted mb-0">作成したもくもく会と参加中のもくもく会を確認できます。</p>
    </div>

    <div class="row">
      <!-- 作成したもくもく会 -->
      <div class="col-md-6 mb-4">
        <div class="card shadow-sm h-100">
          <div class="card-header bg-primary text-white">
            作成したもくもく会
          </div>
          <div class="card-body">
            <% if @owned_groups.any? %>
              <div class="d-flex flex-column gap-3">
                <% @owned_groups.each do |group| %>
                  <div class="border rounded p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <h5 class="fw-bold mb-0"><%= group.name %></h5>
                      <span class="badge text-bg-light border">
                        <%= group.members.count %> / <%= group.max_members %>人
                      </span>
                    </div>

                    <div class="mb-2">
                      <span class="badge text-bg-primary"><%= group.study_theme %></span>
                    </div>

                    <p class="text-secondary mb-2">
                      <%= truncate(group.description, length: 80) %>
                    </p>

                    <div class="d-flex gap-2 flex-wrap">
                      <%= link_to "詳細", group_path(group), class: "btn btn-sm btn-outline-primary" %>
                      <%= link_to "申請管理", requests_group_path(group), class: "btn btn-sm btn-outline-secondary" %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted mb-0">まだ作成したもくもく会はありません。</p>
            <% end %>
          </div>
        </div>
      </div>

      <!-- 参加中のもくもく会 -->
      <div class="col-md-6 mb-4">
        <div class="card shadow-sm h-100">
          <div class="card-header bg-success text-white">
            参加中のもくもく会
          </div>
          <div class="card-body">
            <% if @joined_groups.any? %>
              <div class="d-flex flex-column gap-3">
                <% @joined_groups.each do |group| %>
                  <div class="border rounded p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <h5 class="fw-bold mb-0"><%= group.name %></h5>
                      <span class="badge text-bg-light border">
                        <%= group.members.count %> / <%= group.max_members %>人
                      </span>
                    </div>

                    <div class="mb-2">
                      <span class="badge text-bg-success"><%= group.study_theme %></span>
                    </div>

                    <p class="text-muted mb-1">
                      作成者：<%= group.owner.name %>
                    </p>

                    <p class="text-secondary mb-2">
                      <%= truncate(group.description, length: 80) %>
                    </p>

                    <%= link_to "詳細を見る", group_path(group), class: "btn btn-sm btn-outline-primary" %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted mb-0">まだ参加中のもくもく会はありません。</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", function () {
    const canvas = document.getElementById("studyTimeChart");
    if (!canvas) return;

    if (window.studyTimeChartInstance) {
      window.studyTimeChartInstance.destroy();
    }

    const labels = <%= raw @weekly_study_chart_data.map { |d| d[:label] }.to_json %>;
    const data = <%= raw @weekly_study_chart_data.map { |d| d[:minutes] }.to_json %>;

    window.studyTimeChartInstance = new Chart(canvas, {
      type: "bar",
      data: {
        labels: labels,
        datasets: [{
          label: "学習時間（分）",
          data: data,
          borderWidth: 1,
          backgroundColor: "rgba(54, 162, 235, 0.5)",
          borderColor: "rgba(54, 162, 235, 1)"
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              stepSize: 30
            }
          }
        }
      }
    });
  });
</script>