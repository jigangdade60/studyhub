<div class="container py-4">
  <!-- ページタイトル -->
  <div class="mb-4">
    <h2 class="fw-bold text-primary">マイページ</h2>
    <p class="text-muted mb-0">ログイン中のユーザー情報と投稿一覧を確認できます。</p>
  </div>

  <div class="row">
    <!-- ユーザー情報 -->
    <div class="col-md-4 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
          ユーザー情報
        </div>
        <div class="card-body">
          <!-- ユーザー名 -->
          <p>
            <strong>氏名：</strong>
            <%= @user.name %>
          </p>

          <!-- メールアドレス -->
          <p>
            <strong>メールアドレス：</strong>
            <%= @user.email_address %>
          </p>

          <!-- ボタンエリア -->
          <div class="d-grid gap-2 mt-4">
            <%= link_to "編集する", edit_user_path(@user), class: "btn btn-outline-primary" %>

            <%= button_to "退会する",
                          user_path(@user),
                          method: :delete,
                          data: { turbo_confirm: "本当に退会しますか？この操作は取り消せません。" },
                          class: "btn btn-outline-danger" %>
          </div>
        </div>
      </div>
    </div>

    <!-- 自分の投稿一覧 -->
    <div class="col-md-8">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          自分の投稿一覧
        </div>
        <div class="card-body">
          <% if @posts.any? %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>投稿ID</th>
                    <th>投稿日</th>
                    <th>詳細</th>
                  </tr>
                </thead>
                <tbody>
                  <% @posts.each do |post| %>
                    <tr>
                      <td><%= post.id %></td>
                      <td><%= post.created_at.strftime("%Y/%m/%d %H:%M") %></td>
                      <td>
                        <%= link_to "見る", post_path(post), class: "btn btn-sm btn-outline-secondary" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-muted mb-0">まだ投稿がありません。</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>