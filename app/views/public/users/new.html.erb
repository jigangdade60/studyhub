<h2>新規登録</h2>

<%= form_with model: @user, url: sign_up_path do |f| %>
  <!-- エラーメッセージ -->
  <% if @user.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- ユーザー名 -->
  <div class="mb-3">
    <%= f.label :name, "ユーザー名", class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <!-- メールアドレス -->
  <div class="mb-3">
    <%= f.label :email_address, "メールアドレス", class: "form-label" %>
    <%= f.text_field :email_address, class: "form-control" %>
  </div>

  <!-- パスワード -->
  <div class="mb-3">
    <%= f.label :password, "パスワード", class: "form-label" %>
    <%= f.password_field :password, class: "form-control" %>
  </div>

  <!-- 確認用パスワード -->
  <div class="mb-3">
    <%= f.label :password_confirmation, "確認用パスワード", class: "form-label" %>
    <%= f.password_field :password_confirmation, class: "form-control" %>
  </div>

  <!-- 登録ボタン -->
  <%= f.submit "登録", class: "btn btn-primary" %>
<% end %>