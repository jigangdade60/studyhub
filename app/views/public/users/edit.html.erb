<div class="container py-4" style="max-width: 700px;">
  <!-- ページタイトル -->
  <div class="mb-4">
    <h2 class="fw-bold text-primary">ユーザー情報編集</h2>
    <p class="text-muted mb-0">登録情報を更新できます。</p>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <%= form_with model: @user, local: true do |f| %>
        <!-- エラーメッセージ表示 -->
        <% if @user.errors.any? %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- 氏名 -->
        <div class="mb-3">
          <%= f.label :name, "氏名", class: "form-label" %>
          <%= f.text_field :name, class: "form-control" %>
        </div>

        <!-- メールアドレス -->
        <div class="mb-3">
          <%= f.label :email_address, "メールアドレス", class: "form-label" %>
          <%= f.email_field :email_address, class: "form-control" %>
        </div>

        <!-- プロフィール画像 -->
        <div class="mb-3">
          <%= f.label :profile_image, "プロフィール画像", class: "form-label" %>
          <%= f.file_field :profile_image, class: "form-control", accept: "image/*" %>
        </div>

        <!-- パスワード -->
        <div class="mb-3">
          <%= f.label :password, "新しいパスワード", class: "form-label" %>
          <%= f.password_field :password, class: "form-control" %>
          <div class="form-text">変更しない場合は空欄のままで大丈夫です。</div>
        </div>

        <!-- パスワード確認 -->
        <div class="mb-3">
          <%= f.label :password_confirmation, "新しいパスワード（確認用）", class: "form-label" %>
          <%= f.password_field :password_confirmation, class: "form-control" %>
        </div>

        <!-- ボタン -->
        <div class="d-flex gap-2">
          <%= f.submit "更新する", class: "btn btn-primary" %>
          <%= link_to "戻る", mypage_path, class: "btn btn-outline-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>