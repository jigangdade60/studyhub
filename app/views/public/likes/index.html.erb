<div class="container py-3" style="max-width: 700px;">

  <!-- タイトル -->
  <div class="mb-3">
    <h5 class="fw-bold mb-0">いいね一覧</h5>
  </div>

  <% if @liked_posts.empty? %>
    <div class="bg-white border rounded-4 p-4 text-muted text-center">
      まだいいねした投稿はありません
    </div>
  <% else %>

    <% @liked_posts.each do |post| %>
      <div class="bg-white border rounded-4 mb-3 x-hover"
           style="cursor: pointer;"
           onclick="window.location='<%= post_path(post) %>'">

        <div class="p-3">
          <div class="d-flex gap-3">

            <!-- アイコン -->
            <div onclick="event.stopPropagation();">
              <%= link_to user_path(post.user) do %>
                <%= user_avatar(post.user, size: 48) %>
              <% end %>
            </div>

            <!-- コンテンツ -->
            <div class="flex-grow-1">

              <!-- 名前＋日時 -->
              <div class="mb-1">
                <span onclick="event.stopPropagation();">
                  <%= link_to post.user.name,
                              user_path(post.user),
                              class: "fw-bold text-dark text-decoration-none" %>
                </span>
                <span class="text-muted small ms-2">
                  <%= l post.created_at, format: :short %>
                </span>
              </div>

              <!-- タイトル -->
              <div class="fw-bold text-dark mb-2">
                <%= post.title %>
                <% if Current.user.present? && post.user == Current.user && post.draft? %>
                  <span class="badge bg-secondary rounded-pill ms-2">非公開</span>
                <% end %>
              </div>

              <!-- 本文 -->
              <% if post.body.present? %>
                <div class="text-dark mb-2">
                  <%= truncate(post.body, length: 100) %>
                </div>
              <% end %>

              <!-- 学習時間 -->
              <div class="mb-2">
                <span class="badge bg-light text-success border rounded-pill px-3 py-2">
                  <i class="fa-solid fa-pen me-1"></i><%= format_study_time(post.study_time) %>
                </span>
              </div>

              <!-- タグ -->
              <div class="mb-3" onclick="event.stopPropagation();">
                <% if post.tags.any? %>
                  <% post.tags.each do |tag| %>
                    <%= link_to tag.name,
                                posts_path(tag_name: tag.name),
                                class: "badge bg-light text-primary border me-1 text-decoration-none rounded-pill px-3 py-2" %>
                  <% end %>
                <% end %>
              </div>

              <!-- 下アイコン -->
              <div class="d-flex justify-content-start align-items-center text-muted small pt-2 border-top gap-4">
                <div onclick="event.stopPropagation();">
                  <%= render "public/likes/button", post: post %>
                </div>

                <div class="d-flex align-items-center gap-1">
                  <i class="fa-regular fa-comment"></i>
                  <span><%= post.comments.count %></span>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    <% end %>

  <% end %>
</div>