<div class="container py-3" style="max-width: 700px;">

  <!-- タイトル -->
  <div class="mb-3">
    <h5 class="fw-bold mb-0">いいね一覧</h5>
  </div>

  <% if @liked_posts.empty? %>
    <div class="bg-white border rounded-4 p-4 text-muted text-center">
      まだいいねした投稿はありません
    </div>
  <% else %>

    <% @liked_posts.each do |post| %>
      <div class="bg-white border rounded-4 mb-3 x-hover">

        <%= link_to post_path(post), class: "d-flex gap-3 text-decoration-none text-reset p-3" do %>

          <!-- アイコン -->
          <div>
            <%= image_tag(post.user.profile_image.attached? ? post.user.profile_image : "no_image.jpg",
                          class: "rounded-circle",
                          style: "width: 48px; height: 48px; object-fit: cover;") %>
          </div>

          <!-- コンテンツ -->
          <div class="flex-grow-1">

            <!-- タイトル + ユーザー -->
            <div class="mb-1">
              <span class="fw-bold"><%= post.title %></span>
              <span class="text-muted small ms-2">
                @<%= post.user.name %>
              </span>
            </div>

            <!-- 本文 -->
            <div class="text-dark mb-2">
              <%= truncate(post.body, length: 80) %>
            </div>

            <!-- フッター -->
            <div class="d-flex justify-content-between align-items-center">
              <small class="text-muted">
                学習時間：<%= post.study_time / 60 %>時間<%= post.study_time % 60 %>分
              </small>
            </div>

          </div>

        <% end %>
      </div>
    <% end %>

  <% end %>
</div>