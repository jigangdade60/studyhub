<div class="container py-4" style="max-width: 900px;">
  <div class="mb-4">
    <%= link_to "← もくもく会詳細へ戻る", group_path(@group), class: "text-decoration-none" %>
  </div>

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-4">
    <div>
      <h2 class="fw-bold mb-1">参加申請管理</h2>
      <p class="text-muted mb-0">「<%= @group.name %>」への参加申請を承認・拒否できます。</p>
    </div>
    <span class="badge text-bg-light border fs-6">
      現在 <%= @group.members.count %> / <%= @group.max_members %> 人
    </span>
  </div>

  <% if @requests.empty? %>
    <div class="alert alert-secondary">
      現在、参加申請はありません。
    </div>
  <% else %>
    <div class="card shadow-sm border-0">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>ユーザー名</th>
                <th>申請日時</th>
                <th class="text-center">承認</th>
                <th class="text-center">拒否</th>
              </tr>
            </thead>
            <tbody>
              <% @requests.each do |request| %>
                <tr>
                  <td class="fw-semibold"><%= request.user.name %></td>
                  <td><%= l request.created_at, format: :short %></td>
                  <td class="text-center">
                    <% if @group.full? %>
                      <button class="btn btn-sm btn-secondary" disabled>定員到達</button>
                    <% else %>
                      <%= button_to "承認",
                                    approve_group_join_request_path(request),
                                    method: :patch,
                                    class: "btn btn-sm btn-success" %>
                    <% end %>
                  </td>
                  <td class="text-center">
                    <%= button_to "拒否",
                                  reject_group_join_request_path(request),
                                  method: :patch,
                                  class: "btn btn-sm btn-outline-danger" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>
</div>