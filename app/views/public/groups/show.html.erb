<div class="container py-3" style="max-width: 700px;">

  <!-- タイトル -->
  <div class="mb-3">
    <h5 class="fw-bold mb-0">もくもく会詳細</h5>
  </div>

  <!-- 本体カード -->
  <div class="bg-white border rounded-4 mb-3">
    <div class="p-3">
      <div class="d-flex gap-3">

        <!-- アイコン -->
        <div>
          <%= user_avatar(@group.owner, size: 48) %>
        </div>

        <!-- コンテンツ -->
        <div class="flex-grow-1">

          <!-- 名前＋状態 -->
          <div class="mb-1">
            <span class="fw-bold text-dark"><%= @group.owner.name %></span>
          </div>

          <!-- グループ名 -->
          <div class="fw-bold text-dark mb-2">
            <%= @group.name %>
          </div>

          <!-- テーマ・人数 -->
          <div class="mb-2 d-flex align-items-center flex-wrap gap-2">
            <span class="badge bg-light text-primary border rounded-pill px-3 py-2">
              <%= @group.study_theme %>
            </span>

            <span class="text-muted small">
              <%= @group.members.count %> / <%= @group.max_members %> 人
            </span>

            <% if @group.full? %>
              <span class="badge bg-success rounded-pill">定員到達</span>
            <% else %>
              <span class="badge bg-primary rounded-pill">募集中</span>
            <% end %>
          </div>

          <!-- 説明 -->
          <% if @group.description.present? %>
            <div class="text-dark mb-2">
              <%= simple_format(@group.description) %>
            </div>
          <% end %>

          <!-- ルール -->
          <% if @group.rule.present? %>
            <div class="text-dark mb-2">
              <%= simple_format(@group.rule) %>
            </div>
          <% end %>

        </div>
      </div>
    </div>
  </div>

  <!-- 参加エリア -->
  <div class="bg-white border rounded-4 p-3 mb-3">

    <% if !authenticated? %>
      <p class="mb-2">参加申請にはログインが必要です。</p>
      <%= link_to "ログインする",
                  new_session_path,
                  class: "btn btn-outline-primary rounded-pill px-4" %>

    <% elsif @group.owned_by?(Current.user) %>
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <p class="mb-0">あなたは作成者です</p>
        <%= link_to "申請管理",
                    requests_group_path(@group),
                    class: "x-main-btn rounded-pill px-4" %>
      </div>

    <% elsif @group.joined_by?(Current.user) %>
      <p class="mb-0 text-primary fw-semibold">参加中</p>

    <% elsif @group.pending_request_by?(Current.user) %>
      <p class="mb-0 text-warning fw-semibold">申請中</p>

    <% elsif @group.full? %>
      <p class="mb-0 text-danger fw-semibold">定員に達しています</p>

    <% else %>
      <%= form_with model: [@group, GroupJoinRequest.new], local: true do |f| %>
        <%= f.submit "参加申請する",
                     class: "x-main-btn rounded-pill px-4" %>
      <% end %>
    <% end %>

  </div>

  <!-- メンバー -->
  <div class="bg-white border rounded-4 mb-3">
    <div class="p-3">
      <h5 class="fw-bold mb-3">参加メンバー</h5>

      <% @group.members.each do |member| %>
        <div class="d-flex gap-3 py-2 border-top">

          <div>
            <%= user_avatar(member, size: 40) %>
          </div>

          <div>
            <div class="fw-bold"><%= member.name %></div>
            <% if member == @group.owner %>
              <div class="text-muted small">作成者</div>
            <% end %>
          </div>

        </div>
      <% end %>

    </div>
  </div>

  <!-- チャット -->
  <div class="bg-white border rounded-4">
    <div class="p-3">
      <h5 class="fw-bold mb-3">グループチャット</h5>

      <% if authenticated? && @group.joined_by?(Current.user) %>

        <!-- 投稿フォーム -->
        <div class="mb-3">
          <%= form_with model: [@group, @group_message], local: true do |f| %>
            <%= f.text_area :content,
                            class: "form-control rounded-4",
                            rows: 3,
                            placeholder: "メッセージを入力" %>

            <div class="text-end mt-2">
              <%= f.submit "送信", class: "x-main-btn rounded-pill px-4" %>
            </div>
          <% end %>
        </div>

        <!-- メッセージ -->
        <% @group_messages.each do |message| %>
          <div class="d-flex gap-3 py-3 border-top">

            <div>
              <%= user_avatar(message.user, size: 40) %>
            </div>

            <div class="flex-grow-1">
              <div class="mb-1">
                <span class="fw-bold"><%= message.user.name %></span>
                <span class="text-muted small ms-2">
                  <%= l message.created_at, format: :short %>
                </span>
              </div>

              <div class="text-dark">
                <%= simple_format(message.content) %>
              </div>
            </div>

          </div>
        <% end %>

      <% else %>
        <p class="text-muted mb-0">参加者のみ利用できます</p>
      <% end %>

    </div>
  </div>

</div>