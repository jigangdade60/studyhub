<div class="container py-4" style="max-width: 1000px;">
  <!-- タイトル -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div>
      <h2 class="fw-bold mb-1">もくもく会一覧</h2>
      <p class="text-muted mb-0">興味のあるテーマのもくもく会を探して参加申請できます。</p>
    </div>

    <% if authenticated? %>
      <%= link_to "もくもく会を作成", new_group_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <!-- 検索フォーム -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
      <%= form_with url: groups_path, method: :get, local: true do |f| %>
        <div class="row g-2">
          <div class="col-md-10">
            <%= f.text_field :keyword,
                             value: @keyword,
                             class: "form-control",
                             placeholder: "もくもく会名・学習テーマで検索" %>
          </div>
          <div class="col-md-2 d-grid">
            <%= f.submit "検索", class: "btn btn-outline-primary" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 一覧 -->
  <% if @groups.empty? %>
    <div class="alert alert-secondary">
      該当するもくもく会はありません。
    </div>
  <% else %>
    <div class="row g-4">
      <% @groups.each do |group| %>
        <div class="col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex flex-column">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <h4 class="fw-bold mb-0"><%= group.name %></h4>
                <span class="badge text-bg-light border">
                  <%= group.members.count %>/<%= group.max_members %>人
                </span>
              </div>

              <div class="mb-2">
                <span class="badge text-bg-primary"><%= group.study_theme %></span>
              </div>

              <p class="text-muted mb-2">
                作成者：<%= group.owner.name %>
              </p>

              <p class="mb-3 text-secondary">
                <%= truncate(group.description, length: 100) %>
              </p>

              <div class="mt-auto d-flex justify-content-between align-items-center">
                <% if group.full? %>
                  <span class="text-danger small fw-semibold">定員に達しています</span>
                <% else %>
                  <span class="text-success small fw-semibold">参加者募集中</span>
                <% end %>

                <%= link_to "詳細を見る", group_path(group), class: "btn btn-outline-primary btn-sm" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>