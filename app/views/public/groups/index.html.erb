<div class="container py-3" style="max-width: 700px;">

  <!-- タイトル -->
  <div class="mb-3">
    <h5 class="fw-bold mb-0">もくもく会</h5>
  </div>

  <!-- 検索 -->
  <div class="mb-3">
    <%= form_with url: groups_path, method: :get, local: true do |f| %>
      <%= f.text_field :keyword,
                       value: @keyword,
                       class: "form-control rounded-pill",
                       placeholder: "もくもく会を検索" %>
    <% end %>
  </div>

  <!-- 作成ボタン -->
  <% if authenticated? %>
    <div class="mb-3 text-end">
      <%= link_to new_group_path, class: "x-create-group-btn" do %>
        <i class="fa-solid fa-plus me-2"></i>作成
      <% end %>
    </div>
  <% end %>

  <!-- 一覧 -->
  <% if @groups.empty? %>
    <div class="bg-white border rounded-4 p-4 text-muted text-center">
      該当するもくもく会はありません
    </div>
  <% else %>

    <% @groups.each do |group| %>
      <div class="bg-white border rounded-4 mb-3 x-hover">
        <%= link_to group_path(group), class: "d-flex gap-3 text-decoration-none text-reset p-3" do %>

          <!-- アイコン -->
          <div>
            <%= image_tag(group.owner.profile_image.attached? ? group.owner.profile_image : "no_image.jpg",
                          class: "rounded-circle",
                          style: "width: 48px; height: 48px; object-fit: cover;") %>
          </div>

          <!-- コンテンツ -->
          <div class="flex-grow-1">

            <!-- 名前＋人数 -->
            <div class="d-flex justify-content-between">
              <div>
                <span class="fw-bold"><%= group.name %></span>
                <span class="text-muted small ms-2">
                  参加人数：<%= group.members.count %>/<%= group.max_members %>
                </span>
              </div>
            </div>

            <!-- テーマ -->
            <div class="text-primary small mb-1">
              #<%= group.study_theme %>
            </div>

            <!-- 説明 -->
            <div class="text-dark mb-2">
              <%= truncate(group.description, length: 80) %>
            </div>

            <!-- フッター -->
            <div class="d-flex justify-content-between align-items-center">
              <% if group.full? %>
                <span class="text-danger small">満員</span>
              <% else %>
                <span class="text-success small">募集中</span>
              <% end %>
            </div>

          </div>
        <% end %>
      </div>
    <% end %>

  <% end %>
</div>