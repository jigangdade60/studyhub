<div class="container py-4" style="max-width: 760px;">
  <div class="mb-4">
    <h2 class="fw-bold mb-1">もくもく会を作成</h2>
    <p class="text-muted mb-0">学習テーマやルールを設定して、新しいもくもく会を作成できます。</p>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-body p-4">
      <%= form_with model: @group, local: true do |f| %>
        <% if @group.errors.any? %>
          <div class="alert alert-danger">
            <h6 class="fw-bold mb-2"><%= @group.errors.count %>件のエラーがあります</h6>
            <ul class="mb-0">
              <% @group.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="mb-3">
          <%= f.label :name, "もくもく会名", class: "form-label fw-semibold" %>
          <%= f.text_field :name,
                           class: "form-control",
                           placeholder: "例：Rails学習もくもく会" %>
        </div>

        <div class="mb-3">
          <%= f.label :study_theme, "学習テーマ", class: "form-label fw-semibold" %>
          <%= f.text_field :study_theme,
                           class: "form-control",
                           placeholder: "例：Rails / Ruby / ポートフォリオ制作" %>
        </div>

        <div class="mb-3">
          <%= f.label :description, "説明", class: "form-label fw-semibold" %>
          <%= f.text_area :description,
                          class: "form-control",
                          rows: 4,
                          placeholder: "このもくもく会で学ぶ内容や目的を書いてください" %>
        </div>

        <div class="mb-3">
          <%= f.label :rule, "ルール", class: "form-label fw-semibold" %>
          <%= f.text_area :rule,
                          class: "form-control",
                          rows: 4,
                          placeholder: "例：入退室自由 / 雑談は休憩時間のみ / 学習報告歓迎" %>
        </div>

        <div class="mb-4">
          <%= f.label :max_members, "定員", class: "form-label fw-semibold" %>
          <%= f.number_field :max_members,
                             class: "form-control",
                             min: 2,
                             max: 100,
                             placeholder: "例：10" %>
        </div>

        <div class="d-flex gap-2">
          <%= f.submit "作成する", class: "btn btn-primary" %>
          <%= link_to "一覧に戻る", groups_path, class: "btn btn-outline-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>