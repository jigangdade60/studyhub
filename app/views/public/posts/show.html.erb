<div class="container py-4">
  <!-- タイトル -->
  <div class="mb-4">
    <h2 class="fw-bold">投稿詳細</h2>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <!-- タイトル -->
      <h3 class="fw-bold mb-3"><%= @post.title %></h3>

      <!-- 投稿者 -->
      <p class="text-muted mb-3">
        投稿者：<%= @post.user.name %>
      </p>

      <!-- 学習時間 -->
      <p class="text-muted mb-3">
        学習時間：<%= format_study_time(@post.study_time) %>
      </p>

      <!-- タグ -->
      <div class="mb-3">
        <strong>タグ：</strong>
        <% if @post.tags.any? %>
          <% @post.tags.each do |tag| %>
            <span class="badge bg-secondary me-1"><%= tag.name %></span>
          <% end %>
        <% else %>
          <span class="text-muted">なし</span>
        <% end %>
      </div>

      <!-- 本文 -->
      <div class="mb-4" style="white-space: pre-wrap;">
        <%= @post.body %>
      </div>

      <!-- 投稿者本人だけに編集・削除ボタンを表示 -->
      <div class="d-flex gap-2">
        <%= link_to "一覧へ戻る", posts_path, class: "btn btn-outline-secondary" %>

        <% if current_user&.id == @post.user_id %>
          <%= link_to "編集する", edit_post_path(@post), class: "btn btn-success" %>

          <%= button_to "削除する",
                        post_path(@post),
                        method: :delete,
                        class: "btn btn-danger",
                        data: { turbo_confirm: "本当に削除しますか？" } %>
        <% end %>
      </div>
    </div>

    <div class="card-footer text-muted small">
      投稿日時：<%= l @post.created_at, format: :long %>
    </div>
  </div>
</div>