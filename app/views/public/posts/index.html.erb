<div class="container py-4" style="max-width: 720px;">
  <!-- タイトルと新規投稿ボタン -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">投稿一覧</h2>

    <% if Current.user.present? %>
      <%= link_to "新規投稿", new_post_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <!-- 検索・ソートフォーム -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
      <%= form_with url: posts_path, method: :get, local: true do |f| %>
        <div class="row g-2">
          <div class="col-md-4">
            <%= f.text_field :keyword,
                             value: params[:keyword],
                             class: "form-control",
                             placeholder: "タイトル・本文を検索" %>
          </div>

          <div class="col-md-3">
            <%= f.select :tag_name,
                         options_for_select(@tags.pluck(:name), params[:tag_name]),
                         { include_blank: "タグを選択" },
                         class: "form-select" %>
          </div>

          <div class="col-md-3">
            <%= f.select :sort,
                         options_for_select(
                           [
                             ["新しい順", "new"],
                             ["古い順", "old"],
                             ["いいね数が多い順", "likes"],
                             ["コメント数が多い順", "comments"]
                           ],
                           @sort || "new"
                         ),
                         {},
                         class: "form-select" %>
          </div>

          <div class="col-md-2 d-grid">
            <%= f.submit "適用", class: "btn btn-outline-primary" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 投稿が0件のとき -->
  <% if @posts.empty? %>
    <div class="alert alert-secondary">
      該当する投稿がありません。
    </div>
  <% else %>
    <div class="d-flex flex-column gap-3">
      <% @posts.each do |post| %>
        <div class="card shadow-sm border-0">
          <div class="card-body">
            <!-- 投稿者情報 -->
            <div class="d-flex justify-content-between align-items-start mb-2">
              <div class="d-flex align-items-center">
                <%= user_avatar(post.user, size: 44) %>

                <div class="ms-2">
                  <div class="fw-bold">
                    <%= post.user.name %>
                  </div>
                  <div class="text-muted small">
                    <%= l post.created_at, format: :short %>
                  </div>
                </div>
              </div>
            </div>

            <!-- 投稿タイトル -->
            <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
              <h5 class="fw-bold mb-0">
                <%= link_to post.title, post_path(post), class: "text-decoration-none text-dark" %>
              </h5>

              <% if Current.user.present? && post.user == Current.user && post.draft? %>
                <span class="badge bg-secondary">非公開</span>
              <% end %>
            </div>

            <!-- 学習時間 -->
            <div class="mb-2">
              <span class="badge bg-primary">
                学習時間: <%= format_study_time(post.study_time) %>
              </span>
            </div>

            <!-- タグ -->
            <div class="mb-2">
              <% if post.tags.any? %>
                <% post.tags.each do |tag| %>
                  <% active_class = params[:tag_name] == tag.name ? "bg-primary" : "bg-secondary" %>

                  <%= link_to tag.name,
                      posts_path(tag_name: tag.name, keyword: params[:keyword], sort: params[:sort]),
                      class: "badge #{active_class} me-1 text-decoration-none" %>
                <% end %>
              <% end %>
            </div>

            <!-- 投稿本文 -->
            <% if post.body.present? %>
              <p class="mb-3 text-secondary">
                <%= truncate(post.body, length: 140) %>
              </p>
            <% end %>

            <!-- コメント数 -->
            <p class="text-muted small mb-2">
              コメント数：<%= post.comments.count %>件
            </p>

            <!-- いいねボタン -->
            <div class="mb-3">
              <%= render "public/likes/button", post: post %>
            </div>

            <!-- アクション -->
            <div>
              <%= link_to "詳細を見る", post_path(post), class: "btn btn-outline-primary btn-sm" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>