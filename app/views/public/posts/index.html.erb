<div class="container py-4" style="max-width: 720px;">
  <!-- タイトルと新規投稿ボタン -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">タイムライン</h2>

    <% if Current.user.present? %>
      <%= link_to "新規投稿", new_post_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <!-- 投稿が0件のとき -->
  <% if @posts.empty? %>
    <div class="alert alert-secondary">
      まだ投稿がありません。
    </div>
  <% else %>
    <div class="d-flex flex-column gap-3">
      <% @posts.each do |post| %>
        <div class="card shadow-sm border-0">
          <div class="card-body">
            <!-- 投稿者情報 -->
            <div class="d-flex justify-content-between align-items-start mb-2">
              <div>
                <div class="fw-bold">
                  <%= post.user.name %>
                </div>
                <div class="text-muted small">
                  <%= l post.created_at, format: :short %>
                </div>
              </div>
            </div>

            <!-- 投稿タイトル -->
            <h5 class="fw-bold mb-2">
              <%= link_to post.title, post_path(post), class: "text-decoration-none text-dark" %>
            </h5>

            <!-- 投稿本文 -->
            <p class="mb-3 text-secondary">
              <%= truncate(post.body, length: 140) %>
            </p>

            <!-- アクション -->
            <div>
              <%= link_to "詳細を見る", post_path(post), class: "btn btn-outline-primary btn-sm" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>