<!-- 投稿フォーム -->
<div class="card shadow-sm border-0 rounded-4">
  <div class="card-body p-4 p-md-5">
    <%= form_with model: post, local: true do |f| %>
      <!-- バリデーションエラー表示 -->
      <% if post.errors.any? %>
        <div class="alert alert-danger rounded-3">
          <h5 class="mb-3"><%= post.errors.count %>件のエラーがあります</h5>
          <ul class="mb-0 ps-3">
            <% post.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- タイトル入力欄 -->
      <div class="mb-4">
        <%= f.label :title, "タイトル", class: "form-label fw-semibold" %>
        <%= f.text_field :title, class: "form-control form-control-lg", placeholder: "学習内容のタイトルを入力" %>
      </div>

      <!-- 学習時間入力欄 -->
      <div class="mb-4">
        <%= f.label :study_time, "学習時間", class: "form-label fw-semibold" %>
        <div class="row g-3 align-items-center">
          <div class="col-md-6">
            <div class="input-group">
              <%= f.number_field :study_time_hour, class: "form-control", min: 0, placeholder: "0" %>
              <span class="input-group-text">時間</span>
            </div>
          </div>

          <div class="col-md-6">
            <div class="input-group">
              <%= f.number_field :study_time_minute, class: "form-control", min: 0, max: 59, placeholder: "0" %>
              <span class="input-group-text">分</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 本文入力欄 -->
      <div class="mb-4">
        <%= f.label :body, "学習内容", class: "form-label fw-semibold" %>
        <%= f.text_area :body, class: "form-control", rows: 6, placeholder: "今日学習したことを入力" %>
      </div>

      <!-- 送信ボタン -->
      <div class="d-flex gap-2">
        <%= f.submit "投稿する", class: "btn btn-primary px-4" %>
        <%= link_to "一覧へ戻る", posts_path, class: "btn btn-outline-secondary px-4" %>
      </div>
    <% end %>
  </div>
</div>