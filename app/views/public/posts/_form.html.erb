<!-- 投稿フォーム -->
<%= form_with model: post, local: true do |f| %>
  <!-- バリデーションエラー表示 -->
  <% if post.errors.any? %>
    <div class="alert alert-danger">
      <h5 class="mb-3"><%= post.errors.count %>件のエラーがあります</h5>
      <ul class="mb-0">
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- タイトル入力欄 -->
  <div class="mb-3">
    <%= f.label :title, "タイトル", class: "form-label" %>
    <%= f.text_field :title, class: "form-control", placeholder: "学習内容のタイトルを入力" %>
  </div>

  <!-- 本文入力欄 -->
  <div class="mb-3">
    <%= f.label :body, "学習内容", class: "form-label" %>
    <%= f.text_area :body, class: "form-control", rows: 8, placeholder: "今日学習したことを入力" %>
  </div>

  <!-- 送信ボタン -->
  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "一覧へ戻る", posts_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>