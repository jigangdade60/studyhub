<div class="dm-page">
  <div class="container px-0" style="max-width: 820px;">
    <!-- ヘッダー -->
    <div class="dm-header px-3 px-md-4">
      <div class="d-flex align-items-center justify-content-between h-100">
        <div class="d-flex align-items-center gap-3">
          <%= link_to user_path(@other_user), class: "dm-back-link" do %>
            <i class="fa-solid fa-arrow-left"></i>
          <% end %>

          <div class="d-flex align-items-center gap-3">
            <div class="dm-header-avatar">
              <% if @other_user.profile_image.attached? %>
                <%= image_tag @other_user.profile_image, class: "dm-user-avatar-img" %>
              <% else %>
                <%= image_tag "no_image.jpg", class: "dm-user-avatar-img" %>
              <% end %>
            </div>

            <div>
              <h2 class="dm-title mb-0"><%= @other_user.name %></h2>
              <p class="dm-subtitle mb-0">メッセージ</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- DM本体 -->
    <div class="dm-card d-flex flex-column">
      <!-- メッセージ一覧 -->
      <div class="dm-messages px-3 px-md-4 pb-4">
        <% if @dm_messages.any? %>
          <div class="d-flex flex-column gap-4">
            <% @dm_messages.each do |message| %>
              <% mine = message.user_id == Current.user.id %>
              <% message_user = mine ? Current.user : message.user %>

              <div class="d-flex <%= mine ? 'justify-content-end' : 'justify-content-start' %>">
                <div class="dm-message-row <%= mine ? 'mine' : 'other' %>">
                  <% unless mine %>
                    <div class="dm-avatar">
                      <% if message_user.profile_image.attached? %>
                        <%= image_tag message_user.profile_image, class: "dm-user-avatar-img" %>
                      <% else %>
                        <%= image_tag "no_image.jpg", class: "dm-user-avatar-img" %>
                      <% end %>
                    </div>
                  <% end %>

                  <div class="dm-bubble-wrap d-flex flex-column <%= mine ? 'align-items-end' : 'align-items-start' %>">
                    <div class="dm-meta">
                      <span class="dm-name"><%= mine ? "あなた" : message_user.name %></span>
                      <span class="dm-time"><%= message.created_at.in_time_zone.strftime("%Y/%m/%d %H:%M") %></span>
                    </div>

                    <div class="dm-bubble <%= mine ? 'mine' : 'other' %>">
                      <div class="dm-content"><%= message.content %></div>
                    </div>
                  </div>

                  <% if mine %>
                    <div class="dm-avatar">
                      <% if Current.user.profile_image.attached? %>
                        <%= image_tag Current.user.profile_image, class: "dm-user-avatar-img" %>
                      <% else %>
                        <%= image_tag "no_image.jpg", class: "dm-user-avatar-img" %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="dm-empty text-center py-5">
            <div class="dm-empty-icon mb-3">
              <i class="fa-regular fa-envelope"></i>
            </div>
            <h4 class="fw-bold mb-2">まだメッセージはありません</h4>
            <p class="text-muted mb-0">最初のDMを送ってみましょう。</p>
          </div>
        <% end %>
      </div>

      <!-- 入力欄 -->
      <div class="dm-form-area px-3 px-md-4 py-3">
        <% if @dm_message.errors.any? %>
          <div class="alert alert-danger rounded-4">
            <ul class="mb-0 ps-3">
              <% @dm_message.errors.full_messages.each do |error_message| %>
                <li><%= error_message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with model: [@dm_room, @dm_message], local: true do |f| %>
          <div class="dm-input-wrap">
            <div class="d-flex align-items-start gap-2">
              <div class="flex-grow-1">
                <%= f.text_area :content,
                                rows: 2,
                                class: "form-control dm-textarea",
                                placeholder: "新しいメッセージを作成",
                                style: "resize: none;" %>
              </div>

              <div>
                <%= button_tag type: "submit", class: "btn dm-submit-icon-btn" do %>
                 <i class="fa-regular fa-paper-plane"></i>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>