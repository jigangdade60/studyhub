<div class="container py-4" style="max-width: 800px;">
  <div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
      <h2 class="fw-bold mb-1">DM</h2>
      <p class="text-muted mb-0"><%= @other_user.name %> さんとのメッセージ</p>
    </div>

    <%= link_to "← 戻る", user_path(@other_user), class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-4" style="background-color: #f8f9fa;">
      <% if @dm_messages.any? %>
        <div class="d-flex flex-column gap-3 mb-4">
          <% @dm_messages.each do |message| %>
            <% mine = message.user_id == Current.user.id %>

            <div class="d-flex <%= mine ? 'justify-content-end' : 'justify-content-start' %>">
              <div class="<%= mine ? 'bg-primary text-white' : 'bg-white border' %> px-3 py-2 rounded-4 shadow-sm"
                   style="max-width: 75%;">
                <div class="small <%= mine ? 'text-white-50' : 'text-muted' %> mb-1">
                  <%= mine ? "あなた" : message.user.name %>
                  ・
                  <%= message.created_at.strftime("%Y/%m/%d %H:%M") %>
                </div>
                <div style="white-space: pre-wrap;"><%= message.content %></div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="alert alert-light border text-muted">
          まだメッセージはありません。最初のDMを送ってみましょう。
        </div>
      <% end %>

      <div class="border-top pt-4">
        <% if @dm_message.errors.any? %>
          <div class="alert alert-danger">
            <ul class="mb-0 ps-3">
              <% @dm_message.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with model: [@dm_room, @dm_message], local: true do |f| %>
          <div class="mb-3">
            <%= f.text_area :content,
                            rows: 3,
                            class: "form-control rounded-3",
                            placeholder: "メッセージを入力" %>
          </div>

          <div class="text-end">
            <%= f.submit "送信", class: "btn btn-primary rounded-pill px-4" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>