<header>
  <nav class="navbar navbar-expand-lg border-bottom shadow-sm">
    <div class="container">

      <!-- アプリ名 -->
      <%= link_to "StudyHub", root_path, class: "navbar-brand fw-bold fs-3" %>

      <!-- ハンバーガー -->
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#studyhubNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>

      <!-- ナビ -->
      <div class="collapse navbar-collapse justify-content-end" id="studyhubNavbar">
        <ul class="navbar-nav align-items-lg-center ms-auto">

          <!-- ★ログイン関係なく表示 -->
          <li class="nav-item me-lg-2">
            <%= link_to "投稿一覧", posts_path, class: "nav-link header-link" %>
          </li>

          <li class="nav-item me-lg-2">
            <%= link_to "もくもく会一覧", groups_path, class: "nav-link header-link" %>
          </li>

          <% if Current.admin.present? %>
            <!-- 管理者ログイン後 -->
            <li class="nav-item me-lg-2">
              <%= link_to "ユーザー管理", admin_users_path, class: "nav-link header-link" %>
            </li>

            <li class="nav-item me-lg-2">
              <%= link_to "コメント管理", admin_comments_path, class: "nav-link header-link" %>
            </li>

            <li class="nav-item me-lg-2">
              <%= link_to "もくもく会管理", admin_groups_path, class: "nav-link header-link" %>
            </li>

            <li class="nav-item mt-2 mt-lg-0">
              <%= button_to "ログアウト",
                            admin_logout_path,
                            method: :delete,
                            class: "btn btn-outline-danger btn-sm px-3" %>
            </li>

          <% elsif authenticated? %>
            <!-- 一般ユーザーログイン後 -->
            <li class="nav-item me-lg-2">
              <%= link_to "ユーザー検索", users_path, class: "nav-link header-link" %>
            </li>

            <li class="nav-item me-lg-2">
              <%= link_to "新規投稿", new_post_path, class: "nav-link header-link" %>
            </li>

            <li class="nav-item me-lg-2">
              <%= link_to "もくもく会作成", new_group_path, class: "nav-link header-link" %>
            </li>

            <li class="nav-item me-lg-2">
              <%= link_to "いいね一覧", likes_path, class: "nav-link header-link" %>
            </li>

            <!-- 通知 -->
            <li class="nav-item me-lg-2">
              <%= link_to notifications_path,
                          class: "nav-link position-relative header-link" do %>
                <span>通知</span>
                <% if unread_notifications_count.positive? %>
                  <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                    <%= unread_notifications_count %>
                  </span>
                <% end %>
              <% end %>
            </li>

            <li class="nav-item me-lg-2">
              <%= link_to mypage_path, class: "nav-link d-flex align-items-center gap-2 header-link" do %>
                <%= user_avatar(Current.user, size: 34) %>
                <span>マイページ</span>
              <% end %>
            </li>

            <li class="nav-item mt-2 mt-lg-0">
              <%= button_to "ログアウト",
                            logout_path,
                            method: :delete,
                            class: "btn btn-outline-success btn-sm px-3" %>
            </li>

          <% else %>
            <!-- 未ログイン -->
            <li class="nav-item me-lg-2">
              <%= link_to "About", about_path, class: "nav-link header-link" %>
            </li>

            <li class="nav-item me-lg-2 mt-2 mt-lg-0">
              <%= link_to "新規登録", new_user_path, class: "btn btn-success btn-sm px-3" %>
            </li>

            <li class="nav-item mt-2 mt-lg-0">
              <%= link_to "ログイン", new_session_path, class: "btn btn-outline-success btn-sm px-3" %>
            </li>
          <% end %>

        </ul>
      </div>
    </div>
  </nav>
</header>